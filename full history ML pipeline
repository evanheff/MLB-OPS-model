# ---- 3. Pull Statcast leaderboards per year ---------------------------------
fetch_statcast_year <- function(y) cache_get(sprintf("statcast_%d", y), {
  # Expected statistics (the stable, essential leaderboard)
  exp_url <- sprintf(paste0("https://baseballsavant.mlb.com/leaderboard/",
                            "expected_statistics?type=batter&year=%d&position=",
                            "&team=&min=50&csv=true"), y)
  ex <- get_savant_csv(exp_url)
  out <- tibble(key_mlbam = as.integer(ex$player_id), yearID = y,
                sc_xwoba = ex$est_woba, sc_xba = ex$est_ba,
                sc_xslg = ex$est_slg, sc_woba = ex$woba)
 
  # Exit velocity & barrels (best-effort; column names vary by Savant version)
  brl <- tryCatch({
    b_url <- sprintf(paste0("https://baseballsavant.mlb.com/leaderboard/",
                            "statcast?type=batter&year=%d&position=&team=",
                            "&min=50&csv=true"), y)
    get_savant_csv(b_url)
  }, error = function(e) NULL)
  if (!is.null(brl) && "player_id" %in% names(brl)) {
    pick <- function(cands) {
      nm <- intersect(cands, names(brl)); if (length(nm)) brl[[nm[1]]] else NA_real_
    }
    bdf <- tibble(
      key_mlbam  = as.integer(brl$player_id),
      sc_barrel  = pick(c("brl_pa","barrels_per_pa_percent","barrel_batted_rate","brl_percent")),
      sc_hardhit = pick(c("ev95percent","hard_hit_percent")),
      sc_ev      = pick(c("avg_hit_speed","exit_velocity_avg")),
      sc_la      = pick(c("avg_hit_angle","launch_angle_avg"))
    )
    out <- left_join(out, bdf, by = "key_mlbam")
  }
  out
})
 
