  summarise(RMSE = sqrt(mean((actual - pred)^2)), .groups = "drop") |>
  mutate(lab = sprintf("RMSE = %.4f", RMSE))

ggplot(pva, aes(actual, pred)) +
  geom_abline(slope = 1, intercept = 0, colour = col_accent, linetype = "dashed") +
  geom_point(alpha = 0.15, size = 0.7, colour = col_model) +
  geom_text(data = rmse_lab, aes(x = 0.45, y = 1.15, label = lab),
            hjust = 0, size = 3.3, inherit.aes = FALSE) +
  facet_wrap(~ model) +
  coord_equal(xlim = c(0.4, 1.2), ylim = c(0.4, 1.2)) +
  labs(title = "Predicted vs. actual next-season OPS (test set)",
       subtitle = "Dashed line = perfect prediction", x = "Actual OPS", y = "Projected OPS")
```

Residuals shrink as plate appearances rise — projections are inherently noisier
for players who got less playing time, the small-sample reliability point:

```{r resid, fig.height=4.8}
tibble(pa_target = test_df$pa_target, resid = y_te - pred_xgb) |>
  ggplot(aes(pa_target, resid)) +
  geom_hline(yintercept = 0, colour = "grey60") +
  geom_point(alpha = 0.2, size = 0.8, colour = col_model) +
  geom_smooth(method = "loess", se = TRUE, colour = col_accent, linewidth = 1) +
  labs(title = "Residuals vs. playing time (XGBoost)",
       subtitle = "Spread narrows as plate appearances rise",
       x = "Plate appearances (projected season)", y = "Actual - Projected OPS")
```

# =============================================================================
# MLB OPS projection -- STATCAST EXTENSION
# Does adding prior-season "expected" stats (xwOBA / xBA / xSLG) improve a
# next-season OPS projection over the traditional-stats model?
# =============================================================================
#
# STAGE 1 of this step is DATA: pull Baseball Savant leaderboards, crosswalk
# Savant's MLBAM ids to Lahman's playerID via the Chadwick register, and join
# lagged Statcast features onto the model table. STAGE 2 is the model
# comparison (same rows, with vs. without Statcast).
#
# *** This script reaches LIVE external sources (Baseball Savant + Chadwick). ***
#   - Requires an internet connection.
#   - First run downloads the Chadwick register (~1-2 min); cached afterwards.
#   - VERIFY: open one Savant URL (printed below) in a browser to confirm the
#     CSV columns. The columns that must exist are est_woba / est_ba / est_slg.
