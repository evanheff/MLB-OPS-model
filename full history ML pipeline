# ---- 6. Model comparison: base vs. base + Statcast (same rows) --------------
metrics <- function(actual, pred) {
  e <- actual - pred
  tibble(RMSE = sqrt(mean(e^2)), MAE = mean(abs(e)),
         R2 = 1 - sum(e^2) / sum((actual - mean(actual))^2))
}
xgb_params <- list(objective = "reg:squarederror", eta = 0.05, max_depth = 3,
                   subsample = 0.8, colsample_bytree = 0.8, min_child_weight = 5)
 
build_mats <- function(df, numf, facf, train_end) {
  form <- as.formula(paste("~", paste(c(numf, facf), collapse = " + ")))
  X <- model.matrix(form, df)[, -1, drop = FALSE]; y <- df$ops_target
  tr <- which(df$yearID <= train_end); te <- which(df$yearID > train_end)
  sc <- which(colnames(X) %in% numf)
  mu <- colMeans(X[tr, sc, drop = FALSE]); s <- apply(X[tr, sc, drop = FALSE], 2, sd); s[s == 0] <- 1
  Xs <- X; Xs[, sc] <- scale(X[, sc], center = mu, scale = s)
  list(Xtr = X[tr, , drop = FALSE], Xte = X[te, , drop = FALSE],
       Xtr_s = Xs[tr, , drop = FALSE], Xte_s = Xs[te, , drop = FALSE],
       ytr = y[tr], yte = y[te])
}
run_models <- function(M, label) {
  cvg <- cv.glmnet(M$Xtr_s, M$ytr, alpha = 0.5, nfolds = 10)
  pg  <- as.numeric(predict(cvg, newx = M$Xte_s, s = "lambda.min"))
  dtr <- xgb.DMatrix(M$Xtr, label = M$ytr)
  cvx <- xgb.cv(xgb_params, dtr, nrounds = 1500, nfold = 5,
                early_stopping_rounds = 40, verbose = 0)
  nb  <- ifelse(!is.null(cvx$best_iteration), cvx$best_iteration,
                which.min(cvx$evaluation_log$test_rmse_mean))
  fx  <- xgb.train(xgb_params, dtr, nrounds = nb)
  px  <- predict(fx, M$Xte)
  list(table = bind_rows(
        metrics(M$yte, pg) |> mutate(model = "Elastic net", features = label),
        metrics(M$yte, px) |> mutate(model = "XGBoost",     features = label)),
       xgb = fx)
}
 
M_base <- build_mats(model_sc, base_num, base_fac, TRAIN_END_SC)
M_full <- build_mats(model_sc, c(base_num, sc_core), base_fac, TRAIN_END_SC)
res_base <- run_models(M_base, "Traditional only")
res_full <- run_models(M_full, "+ Statcast (xStats)")
 
comparison <- bind_rows(res_base$table, res_full$table) |>
  select(model, features, RMSE, MAE, R2) |>
  arrange(model, features)
cat("\nModel comparison (test years > ", TRAIN_END_SC, "):\n", sep = "")
print(comparison)
 
