```{r packages}
pkgs <- c("Lahman", "dplyr", "tidyr", "tibble", "ggplot2",
          "glmnet", "xgboost", "broom", "scales")
new <- pkgs[!pkgs %in% rownames(installed.packages())]
if (length(new)) install.packages(new)
invisible(lapply(pkgs, library, character.only = TRUE))

set.seed(42)

# Tunable knobs
DATA_START    <- 1994   # earliest season to read (need 3 yrs before first target)
TARGET_START  <- 1998   # earliest season we try to project
TRAIN_END     <- 2015   # train on targets <= this year; test on the rest
MIN_PA_TARGET <- 250    # a projected season must have enough PA to be meaningful
MIN_PA_LAG1   <- 100    # require some prior-year signal to make a projection

col_model <- "#2C7FB8"; col_base <- "#BDBDBD"; col_accent <- "#800000"
theme_set(theme_minimal(base_size = 12) +
          theme(panel.grid.minor = element_blank(),
                plot.title = element_text(face = "bold")))
```

## Building the player-season table

Players traded mid-year appear as multiple "stints," so we sum them into one
row per player-season. The 60-game 2020 COVID season is dropped everywhere — its
rates and playing-time totals aren't comparable to full seasons.

```{r batting}
bat_ps <- Batting |>
  filter(yearID >= DATA_START, yearID != 2020) |>
  group_by(playerID, yearID) |>
  summarise(across(c(G, AB, R, H, X2B, X3B, HR, RBI, BB, SO, HBP, SH, SF),
                   ~ sum(.x, na.rm = TRUE)), .groups = "drop") |>
  mutate(
    PA    = AB + BB + HBP + SF,
    TB    = H + X2B + 2 * X3B + 3 * HR,
    AVG   = ifelse(AB > 0, H / AB, NA_real_),
    OBP   = ifelse((AB + BB + HBP + SF) > 0,
                   (H + BB + HBP) / (AB + BB + HBP + SF), NA_real_),
    SLG   = ifelse(AB > 0, TB / AB, NA_real_),
    OPS   = OBP + SLG,
    BBpct = ifelse(PA > 0, BB / PA, NA_real_),
    Kpct  = ifelse(PA > 0, SO / PA, NA_real_),
    BABIP = ifelse((AB - SO - HR + SF) > 0,
                   (H - HR) / (AB - SO - HR + SF), NA_real_)
  )
# League-average OPS per season (the run environment).
league_year <- bat_ps |>
  group_by(yearID) |>
  summarise(H = sum(H), AB = sum(AB), BB = sum(BB), HBP = sum(HBP),
            SF = sum(SF), X2B = sum(X2B), X3B = sum(X3B), HR = sum(HR),
            .groups = "drop") |>
  mutate(lgOBP = (H + BB + HBP) / (AB + BB + HBP + SF),
         lgSLG = (H + X2B + 2 * X3B + 3 * HR) / AB,
         lg_ops = lgOBP + lgSLG) |>
  select(yearID, lg_ops)
lg_ops_overall <- mean(league_year$lg_ops)
```

## Bio, position, and park factor

Height, weight, handedness, and birth date come from the `People` table; primary
position from `Appearances` (which includes DH); and a home-park adjustment from
the batting park factor (`BPF`, where 100 is neutral) of whichever team the
player logged the most at-bats with.

```{r context}
people_df <- tryCatch(get("People"), error = function(e) get("Master"))

bio <- people_df |>
  transmute(playerID, birthYear, birthMonth,
            height = as.numeric(height), weight = as.numeric(weight),
            bats, nameFirst, nameLast)

debut_year <- Batting |>                       # from full record, not the window
  group_by(playerID) |>
  summarise(first_year = min(yearID), .groups = "drop")

park_year <- Batting |>
  filter(yearID >= DATA_START, yearID != 2020) |>
  group_by(playerID, yearID, teamID) |>
  summarise(AB = sum(AB), .groups = "drop") |>
  group_by(playerID, yearID) |>
  slice_max(AB, n = 1, with_ties = FALSE) |>
  ungroup() |>
  left_join(select(Teams, yearID, teamID, BPF), by = c("yearID", "teamID")) |>
  transmute(playerID, yearID, park_bpf = as.numeric(BPF))

pos_year <- Appearances |>
  filter(yearID >= DATA_START, yearID != 2020) |>
  group_by(playerID, yearID) |>
  summarise(across(c(G_c, G_1b, G_2b, G_3b, G_ss, G_lf, G_cf, G_rf, G_dh),
                   ~ sum(.x, na.rm = TRUE)), .groups = "drop") |>
  mutate(OF = G_lf + G_cf + G_rf) |>
  transmute(playerID, yearID, C = G_c, `1B` = G_1b, `2B` = G_2b,
            `3B` = G_3b, SS = G_ss, OF = OF, DH = G_dh) |>
  pivot_longer(-c(playerID, yearID), names_to = "primary_pos", values_to = "G") |>
  filter(G > 0) |>
  group_by(playerID, yearID) |>
  slice_max(G, n = 1, with_ties = FALSE) |>
  ungroup() |>
  select(playerID, yearID, primary_pos)
```

## Assembling lags, the Marcel blend, and the target

The lagged frames are shifted forward so a player's *T−1/T−2/T−3* stats line up
with the season we're projecting. `marcel_ops` is a recency- and playing-time-
weighted blend of the last three seasons, regressed toward league average with a
simple age adjustment — it serves as both a strong **baseline** and a model
**feature**.

```{r assemble}
lag1 <- bat_ps |>
  transmute(playerID, yearID = yearID + 1,
            lag1_OBP = OBP, lag1_SLG = SLG, lag1_AVG = AVG, lag1_OPS = OPS,
            lag1_BBpct = BBpct, lag1_Kpct = Kpct, lag1_BABIP = BABIP, lag1_PA = PA)
lag2 <- bat_ps |> transmute(playerID, yearID = yearID + 2, lag2_OPS = OPS, lag2_PA = PA)
lag3 <- bat_ps |> transmute(playerID, yearID = yearID + 3, lag3_OPS = OPS, lag3_PA = PA)
target <- bat_ps |> transmute(playerID, yearID, ops_target = OPS, pa_target = PA)

model_df <- target |>
  left_join(lag1, by = c("playerID", "yearID")) |>
  left_join(lag2, by = c("playerID", "yearID")) |>
  left_join(lag3, by = c("playerID", "yearID")) |>
  left_join(bio, by = "playerID") |>
  left_join(debut_year, by = "playerID") |>
  left_join(mutate(pos_year,  yearID = yearID + 1), by = c("playerID", "yearID")) |>
  left_join(mutate(park_year, yearID = yearID + 1), by = c("playerID", "yearID")) |>
  left_join(transmute(league_year, yearID = yearID + 1, lag1_lg_ops = lg_ops),
            by = "yearID") |>
  mutate(age = yearID - birthYear - ifelse(!is.na(birthMonth) & birthMonth > 6, 1, 0),
         experience = yearID - first_year,
         age_sq = age^2)

w1 <- 5; w2 <- 4; w3 <- 3; REG <- 300
model_df <- model_df |>
  mutate(
    o1 = coalesce(lag1_OPS, 0), p1 = coalesce(lag1_PA, 0),
    o2 = coalesce(lag2_OPS, 0), p2 = coalesce(lag2_PA, 0),
    o3 = coalesce(lag3_OPS, 0), p3 = coalesce(lag3_PA, 0),
    num = w1 * p1 * o1 + w2 * p2 * o2 + w3 * p3 * o3,
    den = w1 * p1 + w2 * p2 + w3 * p3,
    lgb = coalesce(lag1_lg_ops, lg_ops_overall),
    marcel_raw = (num + lgb * REG) / (den + REG),
    age_factor = ifelse(age < 29, 1 + (29 - age) * 0.006, 1 + (29 - age) * 0.003),
    marcel_ops = marcel_raw * age_factor
  ) |>
  select(-o1, -o2, -o3, -p1, -p2, -p3, -num, -den, -lgb, -marcel_raw, -age_factor)
```

## A clean, modern, qualified sample

`lag1_OPS` is deliberately **excluded** from the model features (it equals
`lag1_OBP + lag1_SLG`, so it would be perfectly collinear) — but it still powers
the persistence baseline.

```{r sample}
num_feats <- c("lag1_OBP", "lag1_SLG", "lag1_AVG", "lag1_BBpct", "lag1_Kpct",
               "lag1_BABIP", "lag1_PA", "marcel_ops", "age", "age_sq",
               "experience", "height", "weight", "park_bpf")
fac_feats <- c("bats", "primary_pos")

model_df <- model_df |>
  filter(yearID >= TARGET_START,
         !is.na(lag1_OBP), lag1_PA >= MIN_PA_LAG1, pa_target >= MIN_PA_TARGET,
         !is.na(primary_pos), !is.na(park_bpf), bats %in% c("L", "R", "B"),
         !is.na(height), !is.na(weight), !is.na(age), !is.na(experience)) |>
  filter(if_all(all_of(num_feats), ~ !is.na(.))) |>
  mutate(bats = factor(bats), primary_pos = factor(primary_pos))

sprintf("Modeling rows: %d  |  players: %d  |  target years: %d-%d",
        nrow(model_df), n_distinct(model_df$playerID),
        min(model_df$yearID), max(model_df$yearID))
```

## Design matrix, temporal split, standardization

The split is **by season, not random** — we train on targets through `r 2015`
and test on later years, so the future never leaks into the past. Continuous
features are standardized using *training* statistics applied to the test set,
which makes the linear coefficients comparable in magnitude; the tree model uses
the raw matrix.

```{r split}
form  <- as.formula(paste("~", paste(c(num_feats, fac_feats), collapse = " + ")))
X_all <- model.matrix(form, data = model_df)[, -1, drop = FALSE]
y_all <- model_df$ops_target

train_idx <- which(model_df$yearID <= TRAIN_END)
test_idx  <- which(model_df$yearID >  TRAIN_END)
train_df  <- model_df[train_idx, ]; test_df <- model_df[test_idx, ]

X_tr_raw <- X_all[train_idx, , drop = FALSE]; X_te_raw <- X_all[test_idx, , drop = FALSE]
y_tr <- y_all[train_idx]; y_te <- y_all[test_idx]

scale_cols <- which(colnames(X_all) %in% num_feats)
mu  <- colMeans(X_tr_raw[, scale_cols, drop = FALSE])
sdv <- apply(X_tr_raw[, scale_cols, drop = FALSE], 2, sd); sdv[sdv == 0] <- 1
X_tr_std <- X_tr_raw; X_te_std <- X_te_raw
X_tr_std[, scale_cols] <- scale(X_tr_raw[, scale_cols], center = mu, scale = sdv)
X_te_std[, scale_cols] <- scale(X_te_raw[, scale_cols], center = mu, scale = sdv)
```

## Baselines and models

```{r models}
metrics <- function(actual, pred) {
  e <- actual - pred
  tibble(RMSE = sqrt(mean(e^2)), MAE = mean(abs(e)),
         R2 = 1 - sum(e^2) / sum((actual - mean(actual))^2))
}

# Baselines
pred_base_mean <- coalesce(test_df$lag1_lg_ops, lg_ops_overall)
pred_persist   <- test_df$lag1_OPS
pred_marcel    <- test_df$marcel_ops

# Linear regression (standardized -> comparable coefficients)
lm_tr <- as.data.frame(X_tr_std); lm_tr$y <- y_tr
lm_fit  <- lm(y ~ ., data = lm_tr)
pred_lm <- predict(lm_fit, newdata = as.data.frame(X_te_std))

# Elastic net
cv_gn   <- cv.glmnet(X_tr_std, y_tr, alpha = 0.5, nfolds = 10)
pred_gn <- as.numeric(predict(cv_gn, newx = X_te_std, s = "lambda.min"))

# Gradient-boosted trees (raw features)
dtr <- xgb.DMatrix(X_tr_raw, label = y_tr)
dte <- xgb.DMatrix(X_te_raw, label = y_te)
params <- list(objective = "reg:squarederror", eta = 0.05, max_depth = 4,
               subsample = 0.8, colsample_bytree = 0.8)
cv <- xgb.cv(params, dtr, nrounds = 1500, nfold = 5,
             early_stopping_rounds = 40, verbose = 0)
best_n <- ifelse(!is.null(cv$best_iteration), cv$best_iteration,
                 which.min(cv$evaluation_log$test_rmse_mean))
xgb_fit  <- xgb.train(params, dtr, nrounds = best_n)
pred_xgb <- predict(xgb_fit, dte)
```

## Results: do the models beat the baselines?

```{r results}
results <- bind_rows(
  metrics(y_te, pred_base_mean) |> mutate(model = "Baseline: prior-yr league avg"),
  metrics(y_te, pred_persist)   |> mutate(model = "Baseline: persistence"),
  metrics(y_te, pred_marcel)    |> mutate(model = "Baseline: Marcel"),
  metrics(y_te, pred_lm)        |> mutate(model = "Linear regression"),
  metrics(y_te, pred_gn)        |> mutate(model = "Elastic net"),
  metrics(y_te, pred_xgb)       |> mutate(model = "XGBoost")
) |>
  mutate(is_model = !grepl("Baseline", model)) |>
  select(model, RMSE, MAE, R2, is_model) |>
  arrange(RMSE)

gm <- function(m, col) results[[col]][results$model == m]
results |> select(model, RMSE, MAE, R2)
```

```{r results-plot, fig.height=4.5}
ggplot(results, aes(x = reorder(model, -RMSE), y = RMSE, fill = is_model)) +
  geom_col(width = 0.7) +
  geom_text(aes(label = sprintf("%.4f", RMSE)), hjust = -0.1, size = 3.5) +
  scale_fill_manual(values = c(`FALSE` = col_base, `TRUE` = col_model), guide = "none") +
  coord_flip() +
  scale_y_continuous(expand = expansion(mult = c(0, 0.15))) +
  labs(title = "Test-set accuracy vs. baselines",
       subtitle = "Lower RMSE is better (OPS units). Grey = naive baselines.",
       x = NULL, y = "RMSE")
```

**Reading the numbers.** The best model (XGBoost) lands at an RMSE of
`r sprintf("%.4f", gm("XGBoost","RMSE"))` and R² of
`r sprintf("%.3f", gm("XGBoost","R2"))`, against
`r sprintf("%.4f", gm("Baseline: Marcel","RMSE"))` / `r sprintf("%.3f", gm("Baseline: Marcel","R2"))`
for Marcel — roughly an
`r sprintf("%.0f%%", 100 * (gm("Baseline: Marcel","RMSE") - gm("XGBoost","RMSE")) / gm("Baseline: Marcel","RMSE"))`
cut in error. An R² near 0.3 is in the range public projection systems achieve
for this population; next-season OPS is genuinely hard to pin down because of
injury, role changes, and batted-ball luck. Two honest caveats: the models
*contain* `marcel_ops` plus extra signal, so out-performing Marcel is partly by
construction; and the persistence baseline — predicting last year's OPS
unchanged — is the **worst** of all, with a negative R²
(`r sprintf("%.3f", gm("Baseline: persistence","R2"))`). That last point is the
regression-to-the-mean story made concrete: a raw prior-year number over-trusts
last season's noise, and the model's edge comes largely from pulling extremes
back toward the middle.

## What the models learned

### Linear coefficients (standardized)

```{r coef-lm}
coef_lm <- broom::tidy(lm_fit) |>
  filter(term != "(Intercept)") |>
  mutate(lo = estimate - 1.96 * std.error, hi = estimate + 1.96 * std.error)

ggplot(coef_lm, aes(x = estimate, y = reorder(term, estimate))) +
  geom_vline(xintercept = 0, colour = "grey60") +
  geom_segment(aes(x = lo, xend = hi, yend = reorder(term, estimate)), colour = "grey50") +
  geom_point(colour = col_model, size = 2) +
  labs(title = "Linear model: standardized coefficients",
       subtitle = "Effect on projected OPS of a 1-SD increase (95% CI)",
       x = "Coefficient (OPS units per SD)", y = NULL)
```

### Elastic-net retained features

```{r coef-gn}
coef_gn <- as.matrix(coef(cv_gn, s = "lambda.min"))
coef_gn <- tibble(term = rownames(coef_gn), estimate = coef_gn[, 1]) |>
  filter(term != "(Intercept)", estimate != 0)

ggplot(coef_gn, aes(x = estimate, y = reorder(term, estimate))) +
  geom_vline(xintercept = 0, colour = "grey60") +
  geom_col(fill = col_model, width = 0.7) +
  labs(title = "Elastic net: retained coefficients",
       subtitle = "Features shrunk to exactly zero are dropped",
       x = "Coefficient (per SD)", y = NULL)
```

### XGBoost variable importance

```{r imp}
imp <- xgb.importance(model = xgb_fit, feature_names = colnames(X_tr_raw))
ggplot(head(imp, 15), aes(x = Gain, y = reorder(Feature, Gain))) +
  geom_col(fill = col_model, width = 0.7) +
  scale_x_continuous(labels = percent_format(accuracy = 1)) +
  labs(title = "XGBoost: variable importance (gain)",
