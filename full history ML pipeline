# Small cache + robust CSV fetch (browser-like UA; Savant blocks some clients)
cache_get <- function(key, expr) {
  f <- file.path("cache", paste0(key, ".rds"))
  if (file.exists(f)) return(readRDS(f))
  val <- force(expr); saveRDS(val, f); val
}
get_savant_csv <- function(url) {
  resp <- httr::GET(url, httr::user_agent("Mozilla/5.0"))
  httr::stop_for_status(resp)
  readr::read_csv(httr::content(resp, as = "text", encoding = "UTF-8"),
                  show_col_types = FALSE)
}
